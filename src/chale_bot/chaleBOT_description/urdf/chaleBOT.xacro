  <joint name="Revolute_14" type="revolute">
    <origin xyz="0.0 0.0 0.725" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="arm_link_1_1"/>
    <axis xyz="0.0 0.0 1.0"/>
    <limit effort="500" velocity="10" lower="-3.14159" upper="3.14159" />
    <dynamics damping="1.0" friction="0.1"/>
  </joint>

  <joint name="Revolute_15" type="revolute">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="arm_link_1_1"/>
    <child link="arm_link_2_1"/>
    <axis xyz="1 0 0"/>
    <limit effort="500" velocity="10" lower="-3.14159" upper="3.14159" />
    <dynamics damping="1.0" friction="0.1"/>
  </joint>

  <joint name="Revolute_16" type="revolute">
    <origin xyz="0.0 0.0 0.25" rpy="0 0 0"/>
    <parent link="arm_link_2_1"/>
    <child link="arm_link_3_1"/>
    <axis xyz="1 0 0"/>
    <limit effort="500" velocity="10" lower="-3.14159" upper="3.14159" />
    <dynamics damping="1.0" friction="0.1"/>
  </joint>

  <joint name="Revolute_17" type="revolute">
    <origin xyz="0 0 0.25" rpy="0 0 0"/>
    <parent link="arm_link_3_1"/>
    <child link="arm_link_4_1"/>
    <axis xyz="1 0 0"/>
    <limit effort="500" velocity="10" lower="-3.14159" upper="3.14159" />
    <dynamics damping="1.0" friction="0.1"/>
  </joint>

  <joint name="Revolute_18" type="revolute">
    <origin xyz="0.14 0 0.125" rpy="0 0 0"/>
    <parent link="arm_link_4_1"/>
    <child link="arm_link_5_1"/>
    <axis xyz="0 0 1"/>
    <limit effort="500" velocity="10" lower="-3.14159" upper="3.14159" />
    <dynamics damping="1.0" friction="0.1"/>
  </joint>

  <joint name="Rigid_19" type="fixed">
    <origin xyz="0 0 0.125" rpy="0 0 0"/>
    <parent link="arm_link_5_1"/>
    <child link="gripper_stator_1"/>
  </joint>

  <joint name="Slider_20" type="prismatic">
    <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
    <parent link="gripper_stator_1"/>
    <child link="gripper_clamp_1"/>
    <axis xyz="1 0.0 0.0"/>
    <limit lower="0.0" upper="0.08" effort="20" velocity="1" acceleration="0.1"/>
    <dynamics damping="1.0" friction="1.0"/>
  </joint>

  <joint name="Rigid_21" type="fixed">
    <origin xyz="-0.5 0.0 0.5" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="pick_basket_1"/>
  </joint>

  <joint name="Revolute_23" type="continuous">
    <origin xyz="0.375 -0.25 0.125" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="rightFWD_wheel_1"/>
    <axis xyz="0.0 1.0 0.0"/>
    <dynamics damping="1.0" friction="1.0"/>
  </joint>

  <joint name="Revolute_24" type="continuous">
    <origin xyz="-0.375 -0.25 0.125" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="rightAFT_wheel_1"/>
    <axis xyz="0.0 1.0 0.0"/>
    <dynamics damping="1.0" friction="1.0"/>
  </joint>

  <joint name="Revolute_25" type="continuous">
    <origin xyz="-0.375 0.25 0.125" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="leftAFT_wheel_1"/>
    <axis xyz="0.0 1.0 0.0"/>
    <dynamics damping="1.0" friction="1.0"/>
  </joint>

  <joint name="Revolute_26" type="continuous">
    <origin xyz="0.375 0.25 0.125" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="leftFWD_wheel_1"/>
    <axis xyz="0.0 1.0 0.0"/>
    <dynamics damping="1.0" friction="1.0"/>
  </joint>

  <joint name="Revolute_27" type="revolute">
    <origin xyz="0.25 -0.125 0.575" rpy="0 0 -1.5708"/>
    <parent link="base_link"/>
    <child link="camera_1"/>
    <axis xyz="0.0 0.0 1.0"/>
    <limit effort="10" velocity="10" lower="-3.14159" upper="3.14159" />
    <dynamics damping="1.0" friction="1.0"/>
  </joint>

<!--
  ============================================================
  ros2_control block for chaleBOT
  PASTE THIS INSIDE chaleBOT.xacro just before the closing </robot>.

  IMPORTANT (matches SO-ARM101 working pattern):
    * State interface = position ONLY (no velocity)
    * No <param>initial_value</param> hacks needed
    * Hardware plugin uses fully-qualified name
    * Plugin loader is in chaleBOT.gazebo (existing)
  ============================================================
-->

<ros2_control name="chaleBOT_control" type="system">

  <hardware>
    <plugin>gz_ros2_control/GazeboSimSystem</plugin>
  </hardware>

  <!-- ===================== ARM (5 DOF) ===================== -->
  <joint name="Revolute_14">
    <command_interface name="position">
      <param name="min">-3.14159</param>
      <param name="max">3.14159</param>
    </command_interface>
    <state_interface name="position"/>
  </joint>

  <joint name="Revolute_15">
    <command_interface name="position">
      <param name="min">-3.14159</param>
      <param name="max">3.14159</param>
    </command_interface>
    <state_interface name="position"/>
  </joint>

  <joint name="Revolute_16">
    <command_interface name="position">
      <param name="min">-3.14159</param>
      <param name="max">3.14159</param>
    </command_interface>
    <state_interface name="position"/>
  </joint>

  <joint name="Revolute_17">
    <command_interface name="position">
      <param name="min">-3.14159</param>
      <param name="max">3.14159</param>
    </command_interface>
    <state_interface name="position"/>
  </joint>

  <joint name="Revolute_18">
    <command_interface name="position">
      <param name="min">-3.14159</param>
      <param name="max">3.14159</param>
    </command_interface>
    <state_interface name="position"/>
  </joint>

  <!-- ===================== GRIPPER (prismatic) ===================== -->
  <joint name="Slider_20">
    <command_interface name="position">
      <param name="min">0.0</param>
      <param name="max">0.08</param>
    </command_interface>
    <state_interface name="position"/>
  </joint>

  <!-- ===================== CAMERA PAN (revolute) ===================== -->
  <joint name="Revolute_27">
    <command_interface name="position">
      <param name="min">-1.5708</param>
      <param name="max">1.5708</param>
    </command_interface>
    <state_interface name="position"/>
  </joint>

  <!--
    NOT INCLUDED:
      Revolute_23, Revolute_24, Revolute_25, Revolute_26 (wheels)
        -> driven by DiffDrive plugin in chaleBOT.gazebo
      base_footprint_to_base_link (fixed joint)
        -> not actuated, not exposed
  -->

</ros2_control>

</robot>
