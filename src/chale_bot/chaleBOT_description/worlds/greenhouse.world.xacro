<?xml version="1.0"?>
<sdf version="1.11" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- =========================
       Parameters
  ========================== -->
  <xacro:property name="crop_count" value="5"/>
  <xacro:property name="crop_spacing" value="1.2"/>

  <xacro:property name="aisle_width" value="1.0"/>

  <xacro:property name="rail_length" value="${(crop_count - 1) * crop_spacing + 1.0}"/>
  <xacro:property name="rail_width" value="0.05"/>
  <xacro:property name="rail_height" value="0.05"/>
  <xacro:property name="rail_gap" value="0.50"/>

  <xacro:property name="bed_width" value="0.8"/>
  <xacro:property name="bed_height" value="0.30"/>

  <xacro:property name="crop_collision_size" value="0.35 0.35 0.4"/>
  <xacro:property name="crop_scale" value="0.001 0.001 0.002"/>

  <xacro:property name="wall_thickness" value="0.10"/>
  <xacro:property name="wall_height" value="3.0"/>
  <xacro:property name="roof_thickness" value="0.08"/>

  <!-- Fruit sizes: big >= 0.06 m diameter triggers "large bin" sorting -->
  <xacro:property name="big_fruit_radius" value="0.03"/>     <!-- 10 cm diameter -->
  <xacro:property name="small_fruit_radius" value="0.02"/>  <!-- 5 cm diameter -->

  <!-- Derived dimensions -->
  <xacro:property name="row_y_offset" value="${aisle_width/2.0 + bed_width/2.0}"/>
  <xacro:property name="greenhouse_length" value="${rail_length + 3.0}"/>
  <xacro:property name="greenhouse_width" value="${2.0*bed_width + aisle_width + 2.0}"/>
  <xacro:property name="bed_length" value="${rail_length + 0.6}"/>

  <!-- Crop row x start so row is centered -->
  <xacro:property name="crop_x_start" value="${-((crop_count - 1) * crop_spacing) / 2.0}"/>

  <world name="greenhouse_world">

    <physics name="default_physics" type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>300 300</size>
            </plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>300 300</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.8 0.8 0.8 1</ambient>
            <diffuse>0.8 0.8 0.8 1</diffuse>
            <specular>0.8 0.8 0.8 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <light type="directional" name="sun">
      <cast_shadows>false</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <!-- Greenhouse floor -->
    <model name="greenhouse_floor">
      <static>true</static>
      <pose>0 0 0.01 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>${greenhouse_length} ${greenhouse_width} 0.02</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>${greenhouse_length} ${greenhouse_width} 0.02</size>
            </box>
          </geometry>
          <material>
            <ambient>0.45 0.35 0.25 1</ambient>
            <diffuse>0.50 0.40 0.30 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Side walls -->
    <model name="wall_left">
      <static>true</static>
      <pose>0 ${greenhouse_width/2.0} ${wall_height/2.0} 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>${greenhouse_length} ${wall_thickness} ${wall_height}</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>${greenhouse_length} ${wall_thickness} ${wall_height}</size>
            </box>
          </geometry>
          <material>
            <ambient>0.8 0.9 0.9 0.35</ambient>
            <diffuse>0.8 0.9 0.9 0.35</diffuse>
            <specular>0.2 0.2 0.2 0.35</specular>
          </material>
          <transparency>0.5</transparency>
        </visual>
      </link>
    </model>

    <model name="wall_right">
      <static>true</static>
      <pose>0 ${-greenhouse_width/2.0} ${wall_height/2.0} 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>${greenhouse_length} ${wall_thickness} ${wall_height}</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>${greenhouse_length} ${wall_thickness} ${wall_height}</size>
            </box>
          </geometry>
          <material>
            <ambient>0.8 0.9 0.9 0.35</ambient>
            <diffuse>0.8 0.9 0.9 0.35</diffuse>
            <specular>0.2 0.2 0.2 0.35</specular>
          </material>
          <transparency>0.5</transparency>
        </visual>
      </link>
    </model>

    <!-- Front and back walls -->
    <model name="wall_front">
      <static>true</static>
      <pose>${greenhouse_length/2.0} 0 ${wall_height/2.0} 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>${wall_thickness} ${greenhouse_width} ${wall_height}</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>${wall_thickness} ${greenhouse_width} ${wall_height}</size>
            </box>
          </geometry>
          <material>
            <ambient>0.8 0.9 0.9 0.35</ambient>
            <diffuse>0.8 0.9 0.9 0.35</diffuse>
            <specular>0.2 0.2 0.2 0.35</specular>
          </material>
          <transparency>0.5</transparency>
        </visual>
      </link>
    </model>

    <model name="wall_back">
      <static>true</static>
      <pose>${-greenhouse_length/2.0} 0 ${wall_height/2.0} 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>${wall_thickness} ${greenhouse_width} ${wall_height}</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>${wall_thickness} ${greenhouse_width} ${wall_height}</size>
            </box>
          </geometry>
          <material>
            <ambient>0.8 0.9 0.9 0.35</ambient>
            <diffuse>0.8 0.9 0.9 0.35</diffuse>
            <specular>0.2 0.2 0.2 0.35</specular>
          </material>
          <transparency>0.5</transparency>
        </visual>
      </link>
    </model>

    <!-- Roof -->


    <!-- Nursery bed 1 -->
    <model name="nursery_bed_1">
      <static>true</static>
      <pose>0 ${row_y_offset} ${bed_height/2.0} 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>${bed_length} ${bed_width} ${bed_height}</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>${bed_length} ${bed_width} ${bed_height}</size>
            </box>
          </geometry>
          <material>
            <ambient>0.32 0.18 0.08 1</ambient>
            <diffuse>0.42 0.25 0.12 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Nursery bed 2 -->
    <model name="nursery_bed_2">
      <static>true</static>
      <pose>0 ${-row_y_offset} ${bed_height/2.0} 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>${bed_length} ${bed_width} ${bed_height}</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>${bed_length} ${bed_width} ${bed_height}</size>
            </box>
          </geometry>
          <material>
            <ambient>0.32 0.18 0.08 1</ambient>
            <diffuse>0.42 0.25 0.12 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- <model name="rail_left">
      <static>true</static>
      <pose>0 ${(rail_gap/2.0) - rail_width/2} ${rail_height/2.0} 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>${rail_length} ${rail_width} ${rail_height}</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>${rail_length} ${rail_width} ${rail_height}</size>
            </box>
          </geometry>
          <material>
            <ambient>0.3 0.3 0.3 1</ambient>
            <diffuse>0.45 0.45 0.45 1</diffuse>
            <specular>0.2 0.2 0.2 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <model name="rail_right">
      <static>true</static>
      <pose>0 ${(-rail_gap/2.0) + rail_width/2} ${rail_height/2.0} 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>${rail_length} ${rail_width} ${rail_height}</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>${rail_length} ${rail_width} ${rail_height}</size>
            </box>
          </geometry>
          <material>
            <ambient>0.3 0.3 0.3 1</ambient>
            <diffuse>0.45 0.45 0.45 1</diffuse>
            <specular>0.2 0.2 0.2 1</specular>
          </material>
        </visual>
      </link>
    </model> -->

    <!-- =========================
         Crop macro (unchanged)
    ========================== -->
    <xacro:macro name="crop_model" params="name px py pz">
      <model name="${name}">
        <static>true</static>
        <pose>${px} ${py} ${pz} 0 0 0</pose>
        <link name="link">
          <visual name="visual">
          <origin xyz="${px} ${py} ${pz}" rpy="0 0 0"/>
          <!--origin xyz="${s1} ${s2} ${-s3}" rpy="0 0 0"/-->
            <geometry>
              <mesh>
                <uri>package://chaleBOT_description/worlds/models/vegetable_crop/meshes/vegetable_crop.stl</uri>
                <scale>${crop_scale}</scale>
              </mesh>
            </geometry>
            <material>
              <ambient>0.0 0.6 0.0 1</ambient>
              <diffuse>0.0 0.8 0.0 1</diffuse>
              <specular>0.1 0.1 0.1 1</specular>
            </material>
          </visual>
          <collision name="collision">
            <geometry>
              <box>
                <size>${crop_collision_size}</size>
              </box>
            </geometry>
          </collision>
        </link>
      </model>
    </xacro:macro>

    <!-- =========================
         Big fruit macro (10 cm diameter)
    ========================== -->
    <xacro:macro name="big_fruit" params="name px py pz">
      <model name="${name}">
        <static>true</static>
        <pose>${px} ${py} ${pz} 0 0 0</pose>
        <link name="link">
          <visual name="visual">
            <geometry>
              <sphere>
                <radius>${big_fruit_radius}</radius>
              </sphere>
            </geometry>
            <material>
              <ambient>0.6 0.0 0.0 1</ambient>
              <diffuse>0.95 0.1 0.1 1</diffuse>
              <specular>0.2 0.1 0.1 1</specular>
            </material>
          </visual>
          <!-- <collision name="collision">
            <geometry>
              <sphere>
                <radius>${big_fruit_radius}</radius>
              </sphere>
            </geometry>
          </collision> -->
        </link>
      </model>
    </xacro:macro>

    <!-- =========================
         Small fruit macro (5 cm diameter)
    ========================== -->
    <xacro:macro name="small_fruit" params="name px py pz">
      <model name="${name}">
        <static>true</static>
        <pose>${px} ${py} ${pz} 0 0 0</pose>
        <link name="link">
          <visual name="visual">
            <geometry>
              <sphere>
                <radius>${small_fruit_radius}</radius>
              </sphere>
            </geometry>
            <material>
              <ambient>0.6 0.0 0.0 1</ambient>
              <diffuse>0.95 0.1 0.1 1</diffuse>
              <specular>0.2 0.1 0.1 1</specular>
            </material>
          </visual>
          <!-- <collision name="collision">
            <geometry>
              <sphere>
                <radius>${small_fruit_radius}</radius>
              </sphere>
            </geometry>
          </collision> -->
        </link>
      </model>
    </xacro:macro>

    <!-- =========================
         Crops (unchanged)
    ========================== -->
    <!-- Row 1 crops -->
    <xacro:crop_model name="vegetable_crop_r1_01" px="${crop_x_start + 0*crop_spacing}" py="0" pz="-0.25" />
    <xacro:crop_model name="vegetable_crop_r1_02" px="${crop_x_start + 1*crop_spacing}" py="0" pz="-0.25" />
    <xacro:crop_model name="vegetable_crop_r1_03" px="${crop_x_start + 2*crop_spacing}" py="0" pz="-0.25" />
    <xacro:crop_model name="vegetable_crop_r1_04" px="${crop_x_start + 3*crop_spacing}" py="0" pz="-0.25" />
    <xacro:crop_model name="vegetable_crop_r1_05" px="${crop_x_start + 4*crop_spacing}" py="0" pz="-0.25" />

    <!-- Row 2 crops -->
    <xacro:crop_model name="vegetable_crop_r2_01" px="${crop_x_start + 0*crop_spacing}" py="${-row_y_offset*2}" pz="-0.250" />
    <xacro:crop_model name="vegetable_crop_r2_02" px="${crop_x_start + 1*crop_spacing}" py="${-row_y_offset*2}" pz="-0.25" />
    <xacro:crop_model name="vegetable_crop_r2_03" px="${crop_x_start + 2*crop_spacing}" py="${-row_y_offset*2}" pz="-0.25" />
    <xacro:crop_model name="vegetable_crop_r2_04" px="${crop_x_start + 3*crop_spacing}" py="${-row_y_offset*2}" pz="-0.25" />
    <xacro:crop_model name="vegetable_crop_r2_05" px="${crop_x_start + 4*crop_spacing}" py="${-row_y_offset*2}" pz="-0.25" />

    <!-- =========================
         Fruits — Row 1 (positive Y side, near aisle edge)
         The robot drives along the aisle (between the two beds) with its
         camera pointed at -Y. Fruits face the aisle so the camera sees them.
    ========================== -->
    <xacro:big_fruit   name="fruit_r1_01_a" px="2.4" py="-0.55" pz="0.7" />
    <xacro:small_fruit   name="fruit_r1_02_a" px="1.2" py="-0.55" pz="0.7" />
    <xacro:big_fruit   name="fruit_r1_03_a" px="0" py="-0.55" pz="0.6" />
    <xacro:big_fruit   name="fruit_r1_04_a" px="-1.2" py="-0.55" pz="0.6" />
    <xacro:small_fruit   name="fruit_r1_05_a" px="-2.4" py="-0.55" pz="0.6" />
    

    <!-- =========================
         Fruits — Row 2 (negative Y side, on the far row from camera)
         These won't be reachable from the aisle, but provide visual variety.
         Move them or delete them if you only want pickable fruits.
    ========================== -->
    
   
  </world>
</sdf>
